/* pages/index/index.wxss */

.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Statistics */
.stats-container {
  display: flex;
  justify-content: space-around;
  margin-bottom: 60rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Actions */
.actions-container {
  margin-bottom: 60rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  margin-bottom: 24rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.action-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.action-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.action-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* Types Section */
.types-section {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.types-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.type-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.type-name {
  font-size: 28rpx;
  color: var(--text-primary);
}
