/* pages/guanxi/detail/detail.wxss - Guanxi relationship detail page styles */

.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* Loading State */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* Error State */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.error-button {
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

/* Content Container */
.content-container {
  padding: 30rpx;
}

/* Section Card */
.section-card {
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-body {
  padding: 30rpx;
}

/* Info Row */
.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  min-height: 40rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  flex-shrink: 0;
  width: 180rpx;
  font-size: 28rpx;
  color: #999;
  line-height: 40rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 40rpx;
  word-break: break-all;
}

.info-link {
  color: #1890ff;
  text-decoration: underline;
}

/* Status Badge */
.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.status-inactive {
  background-color: #f5f5f5;
  color: #999;
}

/* Period Item */
.period-item {
  padding: 24rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.period-item:last-child {
  margin-bottom: 0;
}

.period-header {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

/* Period Buttons */
.period-button,
.add-period-button {
  width: 100%;
  background-color: #1890ff;
  color: white;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.add-period-button {
  margin: 30rpx;
  width: calc(100% - 60rpx);
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* Note Content */
.note-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* Action Buttons */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background-color: white;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-button {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-button {
  background-color: #1890ff;
  color: white;
}

.delete-button {
  background-color: #ff4d4f;
  color: white;
}

/* Modal Overlay */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-container {
  width: 600rpx;
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  padding: 20rpx 30rpx 40rpx;
}

.modal-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: center;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-button {
  flex: 1;
  height: 100rpx;
  background-color: transparent;
  border: none;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-button::after {
  border: none;
}

.cancel-button {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.confirm-button {
  color: #ff4d4f;
}

/* Dark Mode Support */
@media (prefers-color-scheme: dark) {
  .page-container {
    background-color: #1a1a1a;
  }

  .section-card {
    background-color: #2a2a2a;
    box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.3);
  }

  .section-header {
    border-bottom-color: #3a3a3a;
  }

  .section-title {
    color: #e0e0e0;
  }

  .info-label {
    color: #888;
  }

  .info-value {
    color: #e0e0e0;
  }

  .period-item {
    background-color: #333;
  }

  .note-content {
    color: #ccc;
  }

  .action-buttons {
    background-color: #2a2a2a;
    box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.5);
  }

  .modal-container {
    background-color: #2a2a2a;
  }

  .modal-title {
    color: #e0e0e0;
  }

  .modal-content {
    color: #ccc;
  }

  .modal-footer {
    border-top-color: #3a3a3a;
  }

  .cancel-button {
    color: #ccc;
    border-right-color: #3a3a3a;
  }

  .error-text {
    color: #999;
  }

  .loading-text {
    color: #666;
  }
}

/* Responsive Adjustments */
@media (max-width: 375px) {
  .content-container {
    padding: 20rpx;
  }

  .section-card {
    margin-bottom: 20rpx;
  }

  .info-label {
    width: 160rpx;
  }
}
