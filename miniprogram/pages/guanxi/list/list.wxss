/* pages/guanxi/list/list.wxss */
.guanxi-list-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-actions {
  display: flex;
  align-items: center;
}

.filter-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

.filter-btn .icon {
  font-size: 32rpx;
}

/* Filter Panel */
.filter-panel {
  background-color: #fff;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-group {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.filter-group:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 28rpx;
  color: #666;
  min-width: 140rpx;
}

.picker-value {
  flex: 1;
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

/* Stats Bar */
.stats-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.stats-text {
  font-size: 26rpx;
  color: #999;
}

/* Guanxi List */
.guanxi-list {
  padding: 20rpx 0;
}

.guanxi-item {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.guanxi-item:active {
  background-color: #fafafa;
}

.guanxi-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.character-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.character-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #5b8ff9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.character-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.character-name {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.relationship-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx;
  flex-shrink: 0;
}

.icon-arrow {
  font-size: 40rpx;
  color: #5b8ff9;
  margin-bottom: 8rpx;
}

.relationship-type {
  background-color: #f0f5ff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.type-text {
  font-size: 22rpx;
  color: #5b8ff9;
}

.guanxi-meta {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
}

.meta-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.meta-badge.active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.meta-badge.deduced {
  background-color: #fff7e6;
  color: #fa8c16;
}

/* Empty State */
.empty-state {
  padding: 200rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 140rpx;
  display: block;
  margin-bottom: 40rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* Create Button */
.create-btn {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 112rpx;
  height: 112rpx;
  background-color: #5b8ff9;
  border-radius: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(91, 143, 249, 0.4);
  z-index: 100;
}

.create-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
}
