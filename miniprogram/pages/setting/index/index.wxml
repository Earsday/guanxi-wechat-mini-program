<!--pages/setting/index/index.wxml-->
<view class="setting-page">
  <!-- Header -->
  <view class="page-header">
    <text class="page-title">{{t.settings.title || '设置'}}</text>
  </view>

  <!-- General Settings -->
  <view class="setting-section">
    <view class="section-title">{{t.settings.general || '通用设置'}}</view>
    
    <!-- Language -->
    <view class="setting-item">
      <view class="item-label">
        <text class="label-icon">🌐</text>
        <text class="label-text">{{t.settings.language || '语言'}}</text>
      </view>
      <picker
        mode="selector"
        range="{{localeOptions}}"
        range-key="label"
        value="{{currentLocale}}"
        bindchange="onLanguageChange"
      >
        <view class="item-value">
          <text wx:for="{{localeOptions}}" wx:key="value" wx:if="{{item.value === currentLocale}}">
            {{item.label}}
          </text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- Data Management -->
  <view class="setting-section">
    <view class="section-title">{{t.settings.dataManagement || '数据管理'}}</view>
    
    <!-- View Statistics -->
    <view class="setting-item" bindtap="onViewStats">
      <view class="item-label">
        <text class="label-icon">📊</text>
        <text class="label-text">{{t.settings.statistics || '数据统计'}}</text>
      </view>
      <view class="item-value">
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- Export Data -->
    <view class="setting-item" bindtap="onExportData">
      <view class="item-label">
        <text class="label-icon">📤</text>
        <text class="label-text">{{t.settings.exportData || '导出数据'}}</text>
      </view>
      <view class="item-value">
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- Import Data -->
    <view class="setting-item" bindtap="onImportData">
      <view class="item-label">
        <text class="label-icon">📥</text>
        <text class="label-text">{{t.settings.importData || '导入数据'}}</text>
      </view>
      <view class="item-value">
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- Clear Data -->
    <view class="setting-item danger" bindtap="onClearData">
      <view class="item-label">
        <text class="label-icon">🗑️</text>
        <text class="label-text">{{t.settings.clearData || '清空数据'}}</text>
      </view>
      <view class="item-value">
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- About -->
  <view class="setting-section">
    <view class="section-title">{{t.settings.aboutSection || '关于'}}</view>
    
    <!-- About App -->
    <view class="setting-item" bindtap="onAbout">
      <view class="item-label">
        <text class="label-icon">ℹ️</text>
        <text class="label-text">{{t.settings.about || '关于应用'}}</text>
      </view>
      <view class="item-value">
        <text class="value-text">v{{version}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- Footer -->
  <view class="footer">
    <text class="footer-text">{{t.settings.appName || '关系网小程序'}}</text>
    <text class="footer-version">v{{version}}</text>
  </view>
</view>
