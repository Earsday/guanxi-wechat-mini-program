<!--pages/characters/detail/detail.wxml-->
<view class="container" wx:if="{{character}}">
  <!-- Character info card -->
  <view class="card character-header">
    <text class="character-name">{{character.name}}</text>
    <view class="character-tags">
      <text class="tag" wx:if="{{character.age}}">{{character.age}}岁</text>
      <text class="tag" wx:if="{{character.gender}}">
        {{character.gender === 'male' ? '男' : '女'}}
      </text>
      <text class="tag" wx:if="{{character.chineseZodiac}}">{{character.chineseZodiac}}</text>
    </view>
  </view>

  <!-- Basic info -->
  <view class="card info-section" wx:if="{{character.phone || character.email}}">
    <text class="section-title">联系方式</text>
    <view class="info-item" wx:if="{{character.phone}}">
      <text class="info-label">手机号：</text>
      <text class="info-value">{{character.phone}}</text>
    </view>
    <view class="info-item" wx:if="{{character.email}}">
      <text class="info-label">邮箱：</text>
      <text class="info-value">{{character.email}}</text>
    </view>
  </view>

  <!-- Relationships -->
  <view class="card relationships-section">
    <text class="section-title">关系（{{relationships.length}}）</text>
    <view class="relationships-list" wx:if="{{relationships.length > 0}}">
      <view class="relationship-item" wx:for="{{relationships}}" wx:key="id">
        <text class="relationship-type">{{item.typeName || '未知类型'}}</text>
      </view>
    </view>
    <view class="empty-hint" wx:else>
      <text>暂无关系</text>
    </view>
  </view>

  <!-- Notes -->
  <view class="card notes-section" wx:if="{{character.notes}}">
    <text class="section-title">备注</text>
    <text class="notes-text">{{character.notes}}</text>
  </view>

  <!-- Actions -->
  <view class="actions">
    <button class="btn-action" bindtap="onEdit">编辑</button>
    <button class="btn-action btn-danger" bindtap="onDelete">删除</button>
  </view>
</view>
