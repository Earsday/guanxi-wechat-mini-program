/* pages/characters/detail/detail.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* Header with gradient */
.header-gradient {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 20rpx 60rpx;
  position: relative;
}

.header-gradient::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #f5f5f5;
  border-radius: 40rpx 40rpx 0 0;
}

.character-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* Avatar */
.character-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Character name and info */
.character-name {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.character-alias {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 20rpx;
}

.character-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.tag {
  font-size: 24rpx;
  color: white;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
}

/* Stats section */
.stats-section {
  padding: 0 20rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

/* Tabs */
.tabs {
  display: flex;
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
  cursor: pointer;
}

.tab-item:active {
  transform: scale(0.95);
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.tab-icon {
  font-size: 32rpx;
}

.tab-item.active .tab-icon,
.tab-item.active .tab-label {
  filter: brightness(0) invert(1);
}

.tab-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: white;
}

/* Content */
.content {
  padding: 0 20rpx;
}

.tab-content {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Section header */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.section-action {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.2s;
}

.section-action:active {
  transform: scale(0.9);
}

.action-plus {
  font-size: 32rpx;
  color: white;
  font-weight: 300;
}

/* Info section */
.info-section {
  margin-bottom: 20rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.info-item:active {
  background: #e8e8e8;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  min-width: 100rpx;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.info-action {
  font-size: 32rpx;
  padding: 8rpx;
  cursor: pointer;
}

.info-action:active {
  opacity: 0.6;
}

/* Quick relationships */
.quick-relationships {
  margin-bottom: 20rpx;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 12rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.category-card:active {
  transform: scale(0.95);
  background: #e8e8e8;
}

.category-icon {
  font-size: 48rpx;
}

.category-count {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.category-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* Notes section */
.notes-section {
  margin-bottom: 20rpx;
}

.notes-text {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
}

/* Quick actions */
.quick-actions {
  margin-bottom: 20rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  cursor: pointer;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.action-item:active .action-icon-wrapper {
  transform: scale(0.9);
}

.primary-gradient {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.success-gradient {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.info-gradient {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.warning-gradient {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.action-icon {
  font-size: 40rpx;
}

.action-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* Relationships section */
.relationships-section {
  margin-bottom: 20rpx;
}

.relationships-grouped {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.type-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.type-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  background: linear-gradient(to right, rgba(102, 126, 234, 0.1), transparent);
  border-left: 4rpx solid var(--primary-color);
  border-radius: 4rpx;
}

.type-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.type-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 4rpx 12rpx;
  background: white;
  border-radius: 12rpx;
}

.relationship-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.relationship-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.relationship-card:active {
  transform: scale(0.98);
  background: #e8e8e8;
}

.relationship-character {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rel-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rel-avatar-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.rel-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rel-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.rel-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.rel-details {
  display: flex;
  align-items: center;
}

.rel-direction {
  font-size: 32rpx;
  color: var(--primary-color);
  font-weight: bold;
}

/* Timeline section */
.timeline-section {
  margin-bottom: 20rpx;
}

/* Empty state */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.empty-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 40rpx;
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
}

.empty-action:active {
  transform: scale(0.95);
}

.empty-action-icon {
  font-size: 32rpx;
  font-weight: 300;
}

.empty-action-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* Fixed actions */
.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx;
  background: white;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
  gap: 20rpx;
  z-index: 100;
}

.btn-action {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.2s;
}

.btn-action:active {
  transform: scale(0.95);
}

.btn-edit {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-danger {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
}

.btn-icon {
  font-size: 32rpx;
}

/* Loading state */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: #f5f5f5;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* Dark mode support */
@media (prefers-color-scheme: dark) {
  .container,
  .loading-container {
    background: #1a1a1a;
  }

  .header-gradient::after {
    background: #1a1a1a;
  }

  .tabs {
    background: #2d2d2d;
  }

  .info-item,
  .category-card,
  .relationship-card {
    background: #2d2d2d;
  }

  .info-item:active,
  .category-card:active,
  .relationship-card:active {
    background: #3d3d3d;
  }

  .type-count {
    background: #2d2d2d;
  }

  .actions {
    background: #2d2d2d;
  }
}

/* Responsive design for H5 */
@media (min-width: 768px) {
  .container {
    max-width: 750rpx;
    margin: 0 auto;
  }

  .stats-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .category-grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .relationship-card:hover {
    transform: scale(1.02);
  }

  .action-item:hover .action-icon-wrapper {
    transform: scale(1.1);
  }
}
