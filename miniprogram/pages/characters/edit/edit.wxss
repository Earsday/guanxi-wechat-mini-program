/* pages/characters/edit/edit.wxss */
.edit-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.form-container {
  flex: 1;
  padding: 24rpx;
}

/* Section Styles */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 32rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* Avatar Section */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-uploader {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.avatar-preview,
.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-preview {
  border: 4rpx solid #f0f0f0;
}

.avatar-placeholder {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-placeholder .icon {
  font-size: 80rpx;
  color: #fff;
}

.avatar-btn {
  padding: 16rpx 32rpx;
  background: #07C160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.avatar-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

/* Form Items */
.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item.required .label::after {
  content: '*';
  color: #ff4444;
  margin-left: 8rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.input,
.textarea {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.input:focus,
.textarea:focus {
  background: #fff;
  border-color: #07C160;
  box-shadow: 0 0 0 4rpx rgba(7, 193, 96, 0.1);
}

.textarea {
  min-height: 160rpx;
  line-height: 1.6;
}

/* Picker Styles */
.picker {
  width: 100%;
}

.picker-text {
  width: 100%;
  padding: 20rpx 24rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
}

.picker-text::after {
  content: '';
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #999;
  border-bottom: 3rpx solid #999;
  transform: rotate(45deg);
  margin-left: 16rpx;
  flex-shrink: 0;
}

.picker-text.placeholder {
  color: #999;
}

/* Action Buttons */
.action-buttons {
  display: flex;
  padding: 24rpx;
  gap: 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  safe-area-inset-bottom: constant;
  safe-area-inset-bottom: env(safe-area-inset-bottom);
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: none;
  padding: 0;
  line-height: 1;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-cancel:active {
  background: #e8e8e8;
}

.btn-submit {
  background: #07C160;
  color: #fff;
}

.btn-submit:active {
  background: #06ad56;
}

.btn-submit:disabled {
  background: #ccc;
  color: #999;
}

/* Bottom spacing for scroll */
.bottom-spacing {
  height: 40rpx;
}

/* Responsive Design */
@media (min-width: 768px) {
  .form-container {
    max-width: 750rpx;
    margin: 0 auto;
  }

  .avatar-preview,
  .avatar-placeholder {
    width: 200rpx;
    height: 200rpx;
  }

  .avatar-placeholder .icon {
    font-size: 100rpx;
  }
}

/* Dark Mode Support */
@media (prefers-color-scheme: dark) {
  .edit-page {
    background: #1e1e1e;
  }

  .section {
    background: #2a2a2a;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  }

  .section-title {
    color: #e5e5e5;
    border-bottom-color: #3a3a3a;
  }

  .label {
    color: #b3b3b3;
  }

  .input,
  .textarea {
    background: #3a3a3a;
    color: #e5e5e5;
    border-color: transparent;
  }

  .input:focus,
  .textarea:focus {
    background: #4a4a4a;
    border-color: #07C160;
  }

  .picker-text {
    background: #3a3a3a;
    color: #e5e5e5;
  }

  .picker-text.placeholder {
    color: #666;
  }

  .picker-text::after {
    border-color: #b3b3b3;
  }

  .avatar-preview {
    border-color: #3a3a3a;
  }

  .btn-cancel {
    background: #3a3a3a;
    color: #b3b3b3;
  }

  .btn-cancel:active {
    background: #4a4a4a;
  }

  .action-buttons {
    background: #2a2a2a;
    box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.3);
  }
}

/* Animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section {
  animation: fadeIn 0.3s ease-out;
}

.section:nth-child(2) {
  animation-delay: 0.1s;
}

.section:nth-child(3) {
  animation-delay: 0.2s;
}

.section:nth-child(4) {
  animation-delay: 0.3s;
}
