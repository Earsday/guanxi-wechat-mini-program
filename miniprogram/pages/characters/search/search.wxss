/* pages/characters/search/search.wxss */
.search-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* Search Bar */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-input-wrapper {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  height: 70rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ccc;
  border-radius: 50%;
}

.clear-btn .icon {
  font-size: 36rpx;
  color: #fff;
  line-height: 1;
}

.search-btn {
  margin-left: 20rpx;
  padding: 0 30rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #5b8ff9;
  color: #fff;
  border-radius: 35rpx;
  font-size: 28rpx;
}

/* Loading */
.loading-container {
  padding: 100rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* Search Results */
.search-results {
  padding: 20rpx 0;
}

.results-header {
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.results-count {
  font-size: 26rpx;
  color: #666;
}

.character-list {
  background-color: #fff;
}

.character-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.character-item:active {
  background-color: #f9f9f9;
}

.character-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #5b8ff9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.character-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.character-info {
  flex: 1;
  min-width: 0;
}

.character-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.character-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
  margin-right: 20rpx;
  margin-top: 4rpx;
}

.character-actions {
  margin-left: 20rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
}

/* No Results */
.no-results {
  padding: 150rpx 60rpx;
  text-align: center;
}

.no-results-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.no-results-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.no-results-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* Recent Searches */
.recent-searches {
  background-color: #fff;
  margin-top: 20rpx;
}

.recent-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recent-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.clear-recent {
  font-size: 26rpx;
  color: #5b8ff9;
}

.recent-list {
  padding: 20rpx 30rpx;
}

.recent-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.recent-item:active {
  opacity: 0.6;
}

.recent-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.recent-keyword {
  font-size: 28rpx;
  color: #666;
}

/* Empty State */
.empty-state {
  padding: 200rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 140rpx;
  display: block;
  margin-bottom: 40rpx;
}

.empty-text {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
}
