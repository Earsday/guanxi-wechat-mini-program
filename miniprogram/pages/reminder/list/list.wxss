/* pages/reminder/list/list.wxss */
.reminder-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* Filter Bar */
.filter-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.filter-toggle .icon {
  font-size: 24rpx;
  color: #999;
}

/* Filters Panel */
.filters-panel {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.filter-label {
  font-size: 28rpx;
  color: #666;
}

.picker {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

/* Reminder List */
.reminder-list {
  padding: 20rpx 30rpx;
}

.reminder-item {
  display: flex;
  align-items: flex-start;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
}

.reminder-item.pending {
  border-left: 6rpx solid #1989fa;
}

.reminder-item.triggered {
  border-left: 6rpx solid #ff9800;
}

.reminder-item.dismissed {
  border-left: 6rpx solid #ccc;
  opacity: 0.7;
}

.reminder-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.reminder-content {
  flex: 1;
}

.reminder-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.reminder-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  margin-right: 12rpx;
}

.reminder-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.reminder-status.pending {
  background-color: #e8f4ff;
  color: #1989fa;
}

.reminder-status.triggered {
  background-color: #fff7e6;
  color: #ff9800;
}

.reminder-status.dismissed {
  background-color: #f5f5f5;
  color: #999;
}

.reminder-character {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.reminder-time {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
}

.time-icon {
  margin-right: 8rpx;
}

.reminder-description {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* Reminder Actions */
.reminder-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  width: 100%;
}

.action-btn {
  padding: 12rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
  background-color: #f5f5f5;
}

.action-btn.dismiss {
  color: #ff9800;
  background-color: #fff7e6;
}

.action-btn.edit {
  color: #1989fa;
  background-color: #e8f4ff;
}

.action-btn.delete {
  color: #ff4d4f;
  background-color: #fff1f0;
}

.action-btn::after {
  border: none;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* Loading State */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #999;
}

/* Create Button */
.create-btn {
  position: fixed;
  right: 30rpx;
  bottom: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
  z-index: 100;
}

.create-btn .icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}

.create-btn:active {
  transform: scale(0.95);
}
