/* pages/timeline/index/index.wxss */
.timeline-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* Filter Bar */
.filter-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.filter-toggle .icon {
  font-size: 24rpx;
  color: #999;
}

/* Filters Panel */
.filters-panel {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.filter-label {
  font-size: 28rpx;
  color: #666;
}

.picker {
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

/* Timeline List */
.timeline-list {
  padding: 40rpx 30rpx;
  position: relative;
}

.timeline-item {
  position: relative;
  padding-left: 60rpx;
  margin-bottom: 40rpx;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 0;
  width: 20rpx;
  height: 20rpx;
  background-color: #1989fa;
  border-radius: 50%;
  z-index: 2;
}

.timeline-line {
  position: absolute;
  left: 9rpx;
  top: 25rpx;
  width: 2rpx;
  height: calc(100% + 40rpx);
  background-color: #e4e7ed;
  z-index: 1;
}

/* Event Card */
.event-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.event-time {
  font-size: 24rpx;
  color: #999;
}

.event-type {
  font-size: 32rpx;
}

.event-type.birthday {
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.event-content {
  margin-bottom: 16rpx;
}

.event-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.event-character {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.event-description {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-top: 8rpx;
}

/* Event Actions */
.event-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  padding: 12rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
  background-color: #f5f5f5;
}

.action-btn.edit {
  color: #1989fa;
  background-color: #e8f4ff;
}

.action-btn.delete {
  color: #ff4d4f;
  background-color: #fff1f0;
}

.action-btn::after {
  border: none;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #ccc;
}

/* Loading State */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 40rpx;
  font-size: 28rpx;
  color: #999;
}

/* Create Button */
.create-btn {
  position: fixed;
  right: 30rpx;
  bottom: 30rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
  z-index: 100;
}

.create-btn .icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}

.create-btn:active {
  transform: scale(0.95);
}
