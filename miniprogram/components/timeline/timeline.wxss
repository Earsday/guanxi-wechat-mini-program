/* components/timeline/timeline.wxss */

.timeline-container {
  width: 100%;
  padding: 20rpx;
}

/* Empty state */
.timeline-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* Timeline list */
.timeline-list {
  position: relative;
}

/* Vertical mode (default) */
.timeline-vertical .timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-vertical .timeline-item:last-child {
  padding-bottom: 0;
}

/* Horizontal mode */
.timeline-horizontal {
  overflow-x: auto;
  white-space: nowrap;
}

.timeline-horizontal .timeline-list {
  display: inline-flex;
  flex-direction: row;
}

.timeline-horizontal .timeline-item {
  display: inline-flex;
  flex-direction: column;
  margin-right: 40rpx;
  min-width: 200rpx;
}

/* Timeline marker (dot/icon area) */
.timeline-marker {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #1989fa;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx #1989fa;
  z-index: 2;
}

.timeline-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #1989fa;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  z-index: 2;
}

.icon-text {
  font-size: 24rpx;
}

/* Connecting line */
.timeline-line {
  position: absolute;
  top: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 2rpx;
  height: calc(100% + 40rpx);
  background-color: #e4e7ed;
  z-index: 1;
}

.timeline-horizontal .timeline-line {
  top: 50%;
  left: 48rpx;
  transform: translateY(-50%);
  width: calc(100% + 40rpx);
  height: 2rpx;
}

/* Content area */
.timeline-content {
  flex: 1;
  padding-top: 4rpx;
}

/* Time labels */
.timeline-time {
  display: flex;
  flex-direction: column;
  margin-bottom: 12rpx;
}

.time-absolute {
  font-size: 24rpx;
  color: #909399;
}

.time-relative {
  font-size: 20rpx;
  color: #c0c4cc;
  margin-top: 4rpx;
}

/* Title */
.timeline-title {
  font-size: 30rpx;
  color: #303133;
  font-weight: 500;
  margin-bottom: 8rpx;
  word-wrap: break-word;
  white-space: normal;
}

/* Description */
.timeline-description {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.5;
  margin-bottom: 12rpx;
  word-wrap: break-word;
  white-space: normal;
}

/* Metadata */
.timeline-metadata {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.metadata-item {
  font-size: 22rpx;
  color: #909399;
  padding: 4rpx 12rpx;
  background-color: #f4f4f5;
  border-radius: 4rpx;
}

/* State variations */
.timeline-item.is-current .timeline-dot,
.timeline-item.is-current .timeline-icon {
  background-color: #67c23a;
  box-shadow: 0 0 0 2rpx #67c23a;
  animation: pulse 2s infinite;
}

.timeline-item.is-past .timeline-dot,
.timeline-item.is-past .timeline-icon {
  background-color: #909399;
  box-shadow: 0 0 0 2rpx #909399;
}

.timeline-item.is-past .timeline-title,
.timeline-item.is-past .timeline-description {
  opacity: 0.6;
}

.timeline-item.is-future .timeline-dot,
.timeline-item.is-future .timeline-icon {
  background-color: #e6a23c;
  box-shadow: 0 0 0 2rpx #e6a23c;
}

/* Clickable items */
.timeline-item[bindtap] {
  cursor: pointer;
  transition: background-color 0.2s;
}

.timeline-item[bindtap]:active {
  background-color: #f5f5f5;
}

/* Pulse animation for current items */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.7;
  }
}

/* Icon type classes */
.icon-birthday {
  background-color: #ff6b9d;
}

.icon-anniversary {
  background-color: #ff9500;
}

.icon-meeting {
  background-color: #5ac8fa;
}

.icon-event {
  background-color: #1989fa;
}

.icon-reminder {
  background-color: #e6a23c;
}

.icon-relationship-start {
  background-color: #67c23a;
}

.icon-relationship-end {
  background-color: #f56c6c;
}

.icon-note {
  background-color: #909399;
}

/* Responsive adjustments */
@media (max-width: 750rpx) {
  .timeline-title {
    font-size: 28rpx;
  }
  
  .timeline-description {
    font-size: 24rpx;
  }
  
  .timeline-icon {
    width: 40rpx;
    height: 40rpx;
    font-size: 20rpx;
  }
}
