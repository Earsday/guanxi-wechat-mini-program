/* components/dynamic-form/dynamic-form.wxss */

/* ==================== Container ==================== */
.dynamic-form {
  width: 100%;
}

/* ==================== Loading State ==================== */
.form-loading {
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #5b8ff9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #8c8c8c;
}

/* ==================== Form Fields ==================== */
.form-fields {
  width: 100%;
}

.form-field {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.form-field.has-error {
  background-color: #fff1f0;
}

/* ==================== Field Label ==================== */
.field-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #262626;
}

.required-mark {
  color: #ff4d4f;
  font-size: 28rpx;
  margin-left: 4rpx;
}

/* ==================== Field Input ==================== */
.field-input {
  width: 100%;
}

/* Text Input */
.input-control {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  background: #fafafa;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #262626;
  transition: border-color 0.2s;
}

.input-control:focus {
  background: #ffffff;
  border-color: #5b8ff9;
}

.input-control[disabled] {
  background: #f5f5f5;
  color: #8c8c8c;
}

/* Textarea */
.textarea-control {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 24rpx;
  background: #fafafa;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #262626;
  line-height: 1.5;
  transition: border-color 0.2s;
}

.textarea-control:focus {
  background: #ffffff;
  border-color: #5b8ff9;
}

.textarea-control[disabled] {
  background: #f5f5f5;
  color: #8c8c8c;
}

/* Switch */
switch {
  transform: scale(0.9);
}

/* Picker Display */
.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
  padding: 0 24rpx;
  background: #fafafa;
  border: 1rpx solid #d9d9d9;
  border-radius: 8rpx;
  transition: border-color 0.2s;
}

.picker-display:active {
  background: #f0f0f0;
  border-color: #5b8ff9;
}

.picker-text {
  flex: 1;
  font-size: 28rpx;
  color: #262626;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-text.placeholder {
  color: #bfbfbf;
}

.picker-arrow {
  font-size: 20rpx;
  color: #8c8c8c;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* Readonly Value */
.readonly-value {
  display: block;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #262626;
  line-height: 1.5;
}

/* Checkbox Group */
checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

checkbox {
  transform: scale(0.9);
  margin-right: 16rpx;
}

.checkbox-label {
  font-size: 28rpx;
  color: #262626;
  flex: 1;
}

/* ==================== Field Description ==================== */
.field-description {
  margin-top: 8rpx;
}

.description-text {
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

/* ==================== Field Error ==================== */
.field-error {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
}

.error-text {
  font-size: 24rpx;
  color: #ff4d4f;
  line-height: 1.5;
}

.error-text::before {
  content: '⚠️ ';
}

/* ==================== Empty State ==================== */
.form-empty {
  padding: 80rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8c8c8c;
}

/* ==================== Animations ==================== */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* ==================== Input Placeholders ==================== */
.input-control::placeholder,
.textarea-control::placeholder {
  color: #bfbfbf;
}

/* ==================== Focus States ==================== */
.input-control:focus,
.textarea-control:focus,
.picker-display:focus {
  outline: 2rpx solid #5b8ff9;
  outline-offset: 2rpx;
}

/* ==================== Dark Mode ==================== */
@media (prefers-color-scheme: dark) {
  .form-field {
    border-bottom-color: #303030;
  }

  .form-field.has-error {
    background-color: #2a1215;
  }

  .label-text {
    color: #e8e8e8;
  }

  .input-control,
  .textarea-control {
    background: #1f1f1f;
    border-color: #434343;
    color: #e8e8e8;
  }

  .input-control:focus,
  .textarea-control:focus {
    background: #262626;
    border-color: #5b8ff9;
  }

  .input-control[disabled],
  .textarea-control[disabled] {
    background: #141414;
    color: #595959;
  }

  .picker-display {
    background: #1f1f1f;
    border-color: #434343;
  }

  .picker-display:active {
    background: #262626;
  }

  .picker-text {
    color: #e8e8e8;
  }

  .picker-text.placeholder {
    color: #595959;
  }

  .picker-arrow {
    color: #8c8c8c;
  }

  .readonly-value {
    color: #e8e8e8;
  }

  .checkbox-label {
    color: #e8e8e8;
  }

  .description-text {
    color: #8c8c8c;
  }

  .empty-text,
  .loading-text {
    color: #8c8c8c;
  }
}

/* ==================== Responsive Design ==================== */
@media screen and (max-width: 375px) {
  .form-field {
    padding: 20rpx 24rpx;
  }

  .label-text {
    font-size: 26rpx;
  }

  .input-control,
  .textarea-control,
  .picker-text {
    font-size: 26rpx;
  }
}

/* ==================== Accessibility ==================== */
.input-control:focus,
.textarea-control:focus,
.picker-display:focus,
checkbox:focus + .checkbox-label {
  outline: 2rpx solid #5b8ff9;
  outline-offset: 2rpx;
}

/* ==================== Field Type Specific Styles ==================== */
/* Number Input - Right Aligned */
.input-control[type="number"] {
  text-align: right;
}

/* Date/DateTime Icons */
.picker-arrow {
  font-size: 32rpx;
}

/* Switch Container */
.field-input switch {
  display: block;
}

/* Checkbox/Radio spacing */
checkbox-group {
  padding: 8rpx 0;
}

/* Multi-line Description */
.field-description {
  padding: 8rpx 0;
}

/* ==================== Field Animations ==================== */
.form-field {
  animation: slideIn 0.3s ease-in-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ==================== Validation States ==================== */
.form-field.has-error .input-control,
.form-field.has-error .textarea-control,
.form-field.has-error .picker-display {
  border-color: #ff4d4f;
}

.form-field.has-error .label-text {
  color: #ff4d4f;
}
