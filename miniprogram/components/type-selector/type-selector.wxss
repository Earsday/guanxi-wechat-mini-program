/* components/type-selector/type-selector.wxss */

.type-selector {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
}

/* ============================================================
   Search Box
   ============================================================ */

.search-box {
  padding: 24rpx;
  background: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.search-input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
}

.search-icon {
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: #333;
}

.search-input::placeholder {
  color: #999;
}

.clear-btn {
  padding: 8rpx;
  margin-left: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-btn icon {
  color: #999;
}

/* ============================================================
   Category Tabs
   ============================================================ */

.category-tabs {
  background: #fff;
  border-bottom: 1rpx solid #e5e5e5;
}

.tabs-scroll {
  white-space: nowrap;
}

.tabs-container {
  display: inline-flex;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  margin: 0 8rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  transition: all 0.3s;
  white-space: nowrap;
}

.tab-item.active {
  color: #07C160;
  font-weight: 600;
  border-bottom-color: #07C160;
}

/* ============================================================
   Loading State
   ============================================================ */

.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top-color: #07C160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* ============================================================
   Type List (List Mode)
   ============================================================ */

.types-container {
  flex: 1;
  overflow: hidden;
}

.types-list {
  height: 100%;
}

.type-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.type-item:active:not(.readonly) {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.type-item.selected {
  border: 2rpx solid #07C160;
  box-shadow: 0 2rpx 16rpx rgba(7, 193, 96, 0.15);
}

.type-item.readonly {
  opacity: 0.6;
}

.type-main {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.type-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 40rpx;
}

.type-info {
  flex: 1;
  min-width: 0;
}

.type-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-description {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.type-indicator {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* ============================================================
   Type Grid (Grid Mode)
   ============================================================ */

.types-grid {
  height: 100%;
  padding: 16rpx;
}

.grid-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.grid-item {
  position: relative;
  width: calc(33.333% - 11rpx);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s;
}

.grid-item:active:not(.readonly) {
  transform: scale(0.95);
}

.grid-item.selected {
  border: 2rpx solid #07C160;
  box-shadow: 0 2rpx 16rpx rgba(7, 193, 96, 0.15);
}

.grid-item.readonly {
  opacity: 0.6;
}

.grid-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.grid-icon .icon-text {
  font-size: 36rpx;
}

.grid-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.3;
}

.grid-indicator {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
}

/* ============================================================
   Empty State
   ============================================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ============================================================
   Dark Mode Support
   ============================================================ */

@media (prefers-color-scheme: dark) {
  .type-selector {
    background: #1e1e1e;
  }

  .search-box {
    background: #2a2a2a;
    border-bottom-color: #3a3a3a;
  }

  .search-input-wrapper {
    background: #1e1e1e;
  }

  .search-input {
    color: #e5e5e5;
  }

  .category-tabs {
    background: #2a2a2a;
    border-bottom-color: #3a3a3a;
  }

  .tab-item {
    color: #999;
  }

  .tab-item.active {
    color: #07C160;
  }

  .loading-spinner {
    border-color: #3a3a3a;
    border-top-color: #07C160;
  }

  .type-item {
    background: #2a2a2a;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  }

  .type-item.selected {
    box-shadow: 0 2rpx 16rpx rgba(7, 193, 96, 0.3);
  }

  .type-name {
    color: #e5e5e5;
  }

  .type-description {
    color: #999;
  }

  .grid-item {
    background: #2a2a2a;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  }

  .grid-item.selected {
    box-shadow: 0 2rpx 16rpx rgba(7, 193, 96, 0.3);
  }

  .grid-name {
    color: #e5e5e5;
  }
}

/* ============================================================
   Responsive Design
   ============================================================ */

/* iPad and larger tablets */
@media (min-width: 768px) {
  .grid-item {
    width: calc(25% - 12rpx);
  }
}

/* Small phones */
@media (max-width: 320px) {
  .type-name {
    font-size: 28rpx;
  }

  .type-description {
    font-size: 22rpx;
  }

  .grid-item {
    width: calc(50% - 8rpx);
  }
}
